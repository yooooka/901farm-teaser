---
interface Props {
  title: string;
}
import "../global.css";
import "@fontsource-variable/inter-tight";
import "@fontsource-variable/literata";
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="901farm LLC - We are creative creatures."
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body
    class="bg-black p-8 font-sans text-gray-200 selection:bg-[#0076dd] selection:text-zinc-950"
  >
    <slot />
    <footer>
      <p
        class="text-xs md:text-sm text-center text-pretty font-sans tracking-wide"
      >
        Copyright © 901farm LLC. All rights reserved.
      </p>
    </footer>
  </body>
</html>

<style is:global>
  /* Global styles can be added here */
</style>
