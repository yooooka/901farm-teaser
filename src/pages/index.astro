---
import Layout from "../layouts/Layout.astro";
import Logo from "../components/Logo.astro";
---

<Layout title="901farm LLC">
  <main>
    <h1 class="sr-only">901farm LLC</h1>

    <div
      class="flex flex-col items-center justify-center min-h-[90svh] gap-8 max-w-lg mx-auto text-gray-200"
    >
      <Logo />
      <p
        class="text-center text-lg md:text-xl text-balance font-sans font-[500] tracking-wide"
      >
        We are creative creatures.
      </p>
      <p
        class="text-animation text-center text-lg md:text-xl text-balance font-sans font-[500] tracking-wide text-yellow-400"
      >
        <a
          href="https://store.901farm.com"
          class="underline hover:no-underline underline-offset-4 hover:text-white transition-colors"
        >
          Our store
        </a>
      </p>
    </div>
  </main>
</Layout>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .text-animation {
    opacity: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .text-animation {
      animation: fadeIn 1s ease-out 0.3s forwards;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .text-animation {
      opacity: 1;
    }
  }
</style>
